# Hugging Face Spaces Configuration
# This file is for deployment on Hugging Face Spaces

# Disable database for demo mode
DISABLE_DB=true

# App Configuration
APP_NAME=Customer Success Digital FTE
APP_VERSION=1.0.0
DEBUG=false

# CORS Configuration
# IMPORTANT: After frontend deployment, update this in Hugging Face Spaces settings
# Add your frontend Space URL here (e.g., https://your-username-frontend-space.hf.space)
CORS_ORIGINS=*

# Gmail Configuration (disabled for demo)
GMAIL_POLLING_ENABLED=false

# Groq Configuration (you need to set this in Hugging Face Spaces secrets)
# GROQ_API_KEY=your_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Support Configuration
SUPPORT_EMAIL=support@example.com

# Dashboard Password
DASHBOARD_PASSWORD=demo123
